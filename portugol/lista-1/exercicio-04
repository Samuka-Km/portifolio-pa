programa
{
	
	funcao inicio()
	{
		real n1, n2, n3, n4 
		escreva("Nota do primeiro bismestre: ")
		leia(n1)
		escreva("Nota do segundo bismestre: ")
		leia(n2)
		escreva("Nota do terceiro bismestre: ")
		leia(n3)
		escreva("Nota do quarto bismestre: ")
		leia(n4)
		escreva("Nota final: ") 
		escreva(n1 * 1 + n2 * 2 + n3 * 3 + n4 * 4 / 10) 
	}
}
