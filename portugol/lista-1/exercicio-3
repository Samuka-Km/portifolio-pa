* Descrição: 
*Ler a base e altura de um triângulo. Calcular e exibir a área do triângulo
sabendo que área = base * altura / 2.
*/

programa
{
	
	funcao inicio()
	{
		real b, h 
		escreva("Base= ") 
		leia(b)
		escreva("Altura= ")
		leia(h)
		escreva(b * h / 2)  
	}
}
