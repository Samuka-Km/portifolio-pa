* Descrição: 
Ler um número inteiro. Verificar e exibir se o número é primo.
*/
programa
{
	
	funcao inicio()
	{
		inteiro n1, div = 0 
		escreva("Qual seu número: ")
		leia(n1)

		para (inteiro i = 1; i <= n1; i++)
		{
			se (n1 % i == 0)
			{
				div++
			}
		}

		se (div == 2)
		{
			escreva("Seu número é primo")
		}
		senao 
		{
			escreva("Seu número não é primo")
		}
	}
}
